{
  "name": "obsidian-note-linter",
  "version": "1.0.0",
  "description": "Passive health metrics and linting for your notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "jest",
    "test:unit": "jest --runTestsByPath tests/rules.unit.test.ts",
    "test:feature": "jest --runTestsByPath tests/linter.feature.test.ts",
    "test:integration": "jest --runTestsByPath tests/main.integration.test.ts"
  },
  "devDependencies": {
    "@types/node": "^16.11.26",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "typescript": "4.9.5",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.1"
  }
}
